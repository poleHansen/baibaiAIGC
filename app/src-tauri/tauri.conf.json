{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "baibaiAIGC",
  "version": "0.1.3",
  "identifier": "com.baibaiaigc.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "baibaiAIGC",
        "width": 1440,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 820,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "resources": [
      "../bin/app_service.exe",
      "../../prompts",
      "../../references",
      "../../scripts"
    ],
    "windows": {
      "wix": {
        "language": "zh-CN"
      }
    }
  }
}
